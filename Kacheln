    <script>
        // Bild-Wechsel Logik per Klick
        const inuvetImages = [
            "https://cdn.shopify.com/s/files/1/0827/3648/0599/files/Inuvet_FloraComplex_07-web_1zu1.jpg?v=1771237152",
            "https://cdn.shopify.com/s/files/1/0827/3648/0599/files/Inuvet_Dermin_01_1zu1.jpg?v=1768908247",
            "https://cdn.shopify.com/s/files/1/0827/3648/0599/files/Webshop_Gruppe_EnteroGast_251027_1080px.jpg?v=1761745404"
        ];

        // Die neuen vollflächigen Hover-Bilder (.card__hover-bg) erhalten ebenfalls den Klick-Event!
        document.querySelectorAll('.card__img, .card__hover-bg').forEach(img => {
            img.addEventListener('click', function(e) {
                // Event Propagation stoppen, damit man den Button normal klicken kann
                e.stopPropagation();

                // Finde den aktuellen Index des Bildes (ignoriert eventuelle URL-Parameter Unterschiede)
                let currentIndex = inuvetImages.findIndex(src => this.src.includes(src.split('?')[0]));
                if (currentIndex === -1) currentIndex = 0;
                
                // Setze das nächste Bild im Array
                let nextIndex = (currentIndex + 1) % inuvetImages.length;
                
                // --- NEUE LÖSUNG FÜR ROLLOVER/KLICK-PROBLEM ---
                // Finde die umgebende Karte
                const parentCard = this.closest('.card');
                
                // Finde BEIDE Bilder in dieser Karte (Basis-Bild UND Hover-Bild)
                const imagesToUpdate = parentCard.querySelectorAll('.card__img, .card__hover-bg');
                
                // Ändere die Bildquelle für beide synchron
                imagesToUpdate.forEach(cardImg => {
                    cardImg.style.opacity = '0.5';
                    setTimeout(() => {
                        cardImg.src = inuvetImages[nextIndex];
                        cardImg.style.opacity = '1';
                    }, 150);
                });
            });
            
            // CSS Übergang für den Opacity-Wechsel hinzufügen
            img.style.transition = 'transform 0.4s ease, opacity 0.15s ease';
        });

        // --- Regler für Grid-Breite ---
        const widthSlider = document.getElementById('width-slider');
        const widthVal = document.getElementById('width-val');
        const root = document.documentElement;

        widthSlider.addEventListener('input', function() {
            const newWidth = this.value + 'px';
            widthVal.textContent = newWidth;
            // Aktualisiert die CSS-Variable zur Steuerung des Grids
            root.style.setProperty('--grid-max-width', newWidth);
        });
    </script>
