<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inuvet Produktübersicht - Dynamic Grid Prototype</title>
    <style>
        /* ==========================================================================
           1. DESIGN TOKENS & VARIABLES
           ========================================================================== */
        :root {
            /* Colors */
            --color-primary-green: #78b41b;
            --color-sec-orange: #ff9c00;
            --color-sec-yellow: #ffce00;
            --color-dark: #2e2e2e;
            --color-bg-light-green: #e0eeca;
            --color-bg-light-yellow: #feffdc;
            --color-white: #ffffff;
            --color-grey-light: #f4f4f4;
            --color-grey-mid: #dddddd;

            /* Typography */
            --font-main: "schnebel-sans-me", "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
            
            /* Radius - Strict Rule: 0px everywhere except specific stickers */
            --radius-none: 0px;
        }

        /* ==========================================================================
           2. BASE STYLES & TYPOGRAPHY
           ========================================================================== */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            /* Zwingend kantiges Design für alle Standard-Elemente */
            border-radius: var(--radius-none);
        }

        body {
            font-family: var(--font-main);
            color: var(--color-dark);
            background-color: var(--color-white);
            line-height: 1.5;
            -webkit-font-smoothing: antialiased;
            font-size: 15px;
        }

        /* Headings: Immer Fett, KEINE Text-Transformation */
        h1, h2, h3, h4, h5, h6 {
            font-weight: 700;
            text-transform: none;
            margin-bottom: 0.5em;
            color: var(--color-dark);
            line-height: 1.15;
        }

        p {
            margin-bottom: 1em;
        }

        /* ==========================================================================
           3. COMPONENTS
           ========================================================================== */
        
        /* Header & Logo */
        .site-header {
            padding: 20px;
            text-align: center;
            background-color: var(--color-white);
            margin-bottom: 40px;
        }

        .header-top {
            position: relative;
            max-width: var(--grid-max-width, 1200px); /* Bündig mit dem Grid */
            margin: 0 auto 20px auto;
            display: grid;
            grid-template-columns: 1fr auto 1fr;
            align-items: center;
        }

        .header-top__left { display: flex; justify-content: flex-start; }
        .header-top__center { display: flex; justify-content: center; }
        .header-top__right { display: flex; justify-content: flex-end; }

        .site-header__logo {
            height: 80px; /* Logo deutlich größer */
            width: auto;
            display: block;
        }

        /* Info Toggle (Desktop Only) */
        .info-toggle {
            display: none; /* Auf Mobile versteckt */
            position: relative;
            text-align: left;
        }

        @media (min-width: 768px) {
            .info-toggle {
                display: block;
            }
        }

        .info-toggle summary {
            font-weight: 700;
            color: var(--color-primary-green);
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 10px;
            list-style: none; /* Versteckt den Standard-Pfeil */
        }

        .info-toggle summary::-webkit-details-marker {
            display: none; /* Für Safari */
        }

        .info-toggle summary:hover {
            color: var(--color-dark);
        }

        .info-icon {
            display: inline-flex;
            justify-content: center;
            align-items: center;
            width: 22px;
            height: 22px;
            background-color: var(--color-primary-green);
            color: var(--color-white);
            border-radius: 50%;
            font-size: 14px;
            font-weight: bold;
            font-style: italic;
        }

        /* Das Dropdown legt sich schwebend über den Hintergrund */
        .info-content {
            position: absolute;
            top: 100%;
            left: 0;
            width: 350px;
            background-color: var(--color-white);
            border: 1px solid var(--color-grey-mid);
            padding: 20px;
            margin-top: 15px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.08);
            font-size: 0.95rem;
            color: var(--color-dark);
            line-height: 1.6;
            cursor: default;
            z-index: 100;
        }

        .info-content p:last-child {
            margin-bottom: 0;
        }

        /* Layout Regler Container */
        .layout-controls {
            display: none; /* Auf Mobile versteckt */
            align-items: center;
            gap: 15px;
            font-size: 0.9rem;
            color: var(--color-dark);
        }

        @media (min-width: 768px) {
            .layout-controls {
                display: flex; /* Auf Desktop anzeigen */
            }
        }

        /* Inuvet-Style Range Slider */
        .layout-controls input[type="range"] {
            -webkit-appearance: none;
            width: 160px;
            background: transparent;
        }

        .layout-controls input[type="range"]:focus {
            outline: none;
        }

        /* Webkit (Chrome, Safari, Edge) */
        .layout-controls input[type="range"]::-webkit-slider-runnable-track {
            width: 100%;
            height: 6px;
            cursor: pointer;
            background: var(--color-grey-mid);
            border-radius: 3px;
        }

        .layout-controls input[type="range"]::-webkit-slider-thumb {
            height: 20px;
            width: 20px;
            background: var(--color-primary-green);
            cursor: pointer;
            -webkit-appearance: none;
            margin-top: -7px; /* Zentriert den Thumbnail auf dem Track */
            border-radius: 50%; /* Runder Regler wie gewünscht */
            border: none;
        }

        /* Firefox */
        .layout-controls input[type="range"]::-moz-range-track {
            width: 100%;
            height: 6px;
            cursor: pointer;
            background: var(--color-grey-mid);
            border-radius: 3px;
        }

        .layout-controls input[type="range"]::-moz-range-thumb {
            height: 20px;
            width: 20px;
            background: var(--color-primary-green);
            cursor: pointer;
            border-radius: 50%; /* Runder Regler */
            border: none;
        }

        /* Buttons */
        .btn {
            display: inline-block;
            padding: 15px 35px;
            text-transform: uppercase;
            letter-spacing: 1.3px;
            font-weight: 500;
            text-decoration: none;
            border: none;
            cursor: pointer;
            transition: opacity 0.2s ease, transform 0.1s ease;
            text-align: center;
            font-family: inherit;
        }

        .btn:hover {
            opacity: 0.9;
        }
        
        .btn:active {
            transform: scale(0.98);
        }

        .btn--main, .btn--secondary {
            background-color: var(--color-dark);
            color: var(--color-white);
        }

        .btn--full-width {
            width: 100%;
        }

        /* Fortschrittsbalken */
        .progress-widget {
            margin: 20px 0;
            width: 100%;
        }

        .progress-widget__bar-bg {
            background-color: var(--color-grey-mid);
            height: 12px;
            width: 100%;
            position: relative;
        }

        .progress-widget__bar-fill {
            background-color: var(--color-primary-green);
            height: 100%;
            width: 65%; /* Beispielwert */
            position: absolute;
            top: 0;
            left: 0;
        }

        .progress-widget__labels {
            display: flex;
            justify-content: space-between;
            font-size: 0.85rem;
            margin-top: 8px;
            font-weight: 700;
        }

        /* Rabatt-Sticker */
        .discount-sticker {
            position: absolute;
            top: 10px;
            left: 10px;
            width: 50px;
            height: 50px;
            background-color: var(--color-sec-orange);
            color: var(--color-white);
            /* Ausnahme: 50% Radius */
            border-radius: 50% !important;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.9rem;
            transform: rotate(-12deg);
            z-index: 30; /* Erhöht, damit er über dem Hover-Bild bleibt */
            box-shadow: 0 4px 10px rgba(0,0,0,0.15);
        }

        @media (min-width: 768px) {
            .discount-sticker {
                top: 15px;
                left: 15px;
                width: 70px;
                height: 70px;
                font-size: 1.2rem;
            }
        }

        /* ==========================================================================
           4. DYNAMIC GRID SYSTEM & CARDS (BEM)
           ========================================================================== */
        
        .product-grid {
            display: grid;
            gap: 15px; /* Mobile: etwas kompakter */
            padding: 0 15px 60px 15px;
            max-width: var(--grid-max-width, 1200px); /* Standard 1200px, steuerbar über Regler */
            margin: 0 auto;
            /* Dense sorgt dafür, dass Lücken nahtlos aufgefüllt werden */
            grid-auto-flow: dense;
            grid-template-columns: repeat(2, 1fr); /* MOBILE: 2 Spalten nebeneinander! */
            transition: max-width 0.3s ease;
        }

        /* Tablet (2 Spalten Base, aber mit mehr Gap/Padding) */
        @media (min-width: 768px) {
            .product-grid {
                gap: 20px;
                padding: 0 20px 60px 20px;
                grid-auto-rows: 300px; /* Feste Basis-Höhe für perfekte Skalierung */
            }
        }

        /* Desktop (4 Spalten) */
        @media (min-width: 1024px) {
            .product-grid {
                grid-template-columns: repeat(4, 1fr);
                grid-auto-rows: 350px; 
            }
        }

        /* Card Base */
        .card {
            background-color: var(--color-white);
            display: flex;
            flex-direction: column;
            position: relative;
            border: 1px solid var(--color-grey-mid);
            overflow: hidden; /* Verhindert, dass Bilder überstehen */
            height: 100%;
        }

        .card__img-wrapper {
            position: relative;
            flex: 0 0 auto;
            aspect-ratio: 1 / 1; /* MOBILE: Zwingend quadratisch! */
            background-color: var(--color-grey-light);
        }

        @media (min-width: 768px) {
            .card__img-wrapper {
                aspect-ratio: auto; /* Desktop: Wieder flexible Höhe passend zur Grid-Row */
                min-height: 200px;
                flex: 1 1 auto;
            }
        }

        .card__img {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            object-fit: cover; /* Schneidet Bilder perfekt ab ohne sie zu verzerren */
            cursor: pointer;
            transition: transform 0.4s ease;
        }

        .card__img-wrapper:hover .card__img {
            transform: scale(1.04);
        }

        .card__content {
            padding: 15px; /* Mobile: Weniger Padding für 2 Spalten */
            display: flex;
            flex-direction: column;
            flex: 0 0 auto;
            background-color: inherit;
        }

        .card__title {
            font-size: 1.1rem; /* Mobile: Kleinere Headlines */
        }

        @media (min-width: 768px) {
            .card__content {
                padding: 25px; /* Desktop: Normales Padding */
            }
            .card__title {
                font-size: 1.4rem; /* Desktop: Normale Headlines */
            }
        }

        .card__footer {
            margin-top: auto;
            padding-top: 20px;
            opacity: 0;
            visibility: hidden;
            transform: translateY(10px);
            transition: all 0.3s ease;
        }

        .card:hover .card__footer {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

        /* --- Full-Bleed Hover State (Neuer Effekt) --- */
        .card__hover-view {
            position: absolute;
            inset: 0; /* Füllt die Karte komplett aus */
            z-index: 20;
            opacity: 0;
            visibility: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: opacity 0.4s ease, visibility 0.4s ease;
        }

        .card__hover-bg {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            z-index: 1;
            cursor: pointer;
        }

        /* Kein Abdunkeln mehr beim Rollover */
        .card__hover-overlay {
            position: absolute;
            inset: 0;
            background-color: transparent; 
            z-index: 2;
            pointer-events: none; /* Klicks fallen auf das darunterliegende Bild durch */
        }

        .card__hover-cta {
            position: relative;
            z-index: 3;
            transform: scale(0.95) translateY(10px);
            transition: transform 0.4s ease;
        }

        .card--product:hover .card__hover-view {
            opacity: 1;
            visibility: visible;
        }

        .card--product:hover .card__hover-cta {
            transform: scale(1) translateY(0);
        }

        @media (hover: hover) {
            /* Auf Maus-Geräten den Standard-CTA in Produktkarten ausblenden,
               da stattdessen der zentrierte Hover-Layer gezeigt wird */
            .card--product .card__footer {
                display: none;
            }
        }

        /* Touch-Geräte zeigen Buttons immer an und deaktivieren den Full-Bleed Layer */
        @media (hover: none) {
            .card__footer {
                opacity: 1;
                visibility: visible;
                transform: translateY(0);
            }
            .card__hover-view {
                display: none !important;
            }
        }

        /* --- Grid Modifiers (The Magic) --- */
        
        /* Hilfsklasse: Volle Breite auf Mobile (für reine Text/Promo-Kacheln) */
        .card--full-mobile {
            grid-column: span 2;
        }

        /* 2 Spalten breit auf großen Screens */
        @media (min-width: 768px) {
            .card--col-span-2 {
                grid-column: span 2;
            }
            /* 2 Reihen hoch */
            .card--row-span-2 {
                grid-row: span 2;
            }
            /* 3 Spalten breit */
            .card--col-span-3 {
                grid-column: span 3;
            }
        }

        /* --- Card Types --- */

        /* Promo Card (Spezifische Regel) */
        .card--promo {
            border: 4px solid var(--color-sec-orange);
        }

        @media (min-width: 768px) {
            .card--promo {
                flex-direction: row; /* Links Bild, rechts Text */
            }
            .card--promo .card__img-wrapper {
                flex: 0 0 50%;
                min-height: auto;
            }
            .card--promo .card__content {
                flex: 0 0 50%;
                justify-content: center; /* Text vertikal zentrieren */
            }
        }

        /* Hintergrund-Varianten */
        .card--bg-light-green {
            background-color: var(--color-bg-light-green);
            border-color: transparent;
        }

        .card--bg-light-yellow {
            background-color: var(--color-bg-light-yellow);
            border-color: transparent; /* Entfernt die Kontur bei farbigen Kacheln */
        }

        .card--bg-primary {
            background-color: var(--color-primary-green);
            color: var(--color-white);
            border-color: transparent;
        }

        .card--bg-primary .card__title {
            color: var(--color-white);
        }

        /* ==========================================================================
           5. UTILITIES
           ========================================================================== */
        .text-sec-orange { color: var(--color-sec-orange); }
        .text-primary { color: var(--color-primary-green); }

    </style>
</head>
